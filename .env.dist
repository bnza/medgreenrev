#User UID (id -u) and GID (id -g) for unprivileged user container deployement
USER_UID=1000
USER_GID=1000
APP_ENV=prod

POSTGRES_DATA_DIR=/path/to/volumes/medgreenrev/db

GEOSERVER_ADMIN_USER=geoserver
GEOSERVER_ADMIN_PASSWORD=geoserver

NGINX_HOST=localhost
NGINX_PORT=80
NGINX_PORT_SSL=443
WWW_STATIC_DIR=/path/to/static/dir
CERTBOT_EMAIL=
CLIENT_BODY_SIZE=10M

XDEBUG_MODE=debug
XDEBUG_CLIENT_HOST=host.docker.internal
